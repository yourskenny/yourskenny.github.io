---
const {
  title = "yourskenny | AI Portfolio",
  description = "武汉大学人工智能专业学生的 Agent、CV、DL、RL、EAI 与 NLP 项目作品集",
  image = "/og-image.svg",
  type = "website"
} = Astro.props;

const site = Astro.site ?? new URL("https://yourskenny.top");
const canonical = new URL(Astro.url.pathname, site).toString();
const imageUrl = new URL(image, site).toString();
---

<link rel="canonical" href={canonical} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<meta name="description" content={description} />
<meta property="og:type" content={type} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={imageUrl} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
