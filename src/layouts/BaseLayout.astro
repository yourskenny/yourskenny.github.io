---
import "../styles/global.css";
import Seo from "../components/Seo.astro";

const {
  title = "yourskenny | AI Portfolio",
  description = "武汉大学人工智能专业学生的 Agent、CV、DL、RL、EAI 与 NLP 项目作品集",
  image = "/og-image.svg",
  type = "website"
} = Astro.props;

const navItems = [
  { href: "/", label: "首页" },
  { href: "/projects/", label: "项目" },
  { href: "/courses/", label: "课程" },
  { href: "/blog/", label: "博客" },
  { href: "/research/", label: "研究" },
  { href: "/about/", label: "关于" }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <Seo title={title} description={description} image={image} type={type} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="返回首页">
        <span class="brand-mark">YK</span>
        <span class="brand-text">yourskenny</span>
      </a>
      <nav aria-label="主导航">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>© 2026 yourskenny</span>
      <span>
        <a href="https://github.com/yourskenny">GitHub</a> ·
        <a href="mailto:2023302111391@whu.edu.cn">Email</a>
      </span>
    </footer>
  </body>
</html>
