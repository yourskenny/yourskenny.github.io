---
import "../styles/global.css";
import Seo from "../components/Seo.astro";

const {
  title = "AI Student Portfolio",
  description = "AI 学生的研究潜力与工程能力证明站",
  image = "/og-image.svg",
  type = "website"
} = Astro.props;

const navItems = [
  { href: "/", label: "首页" },
  { href: "/projects/", label: "项目" },
  { href: "/blog/", label: "博客" },
  { href: "/research/", label: "研究" },
  { href: "/about/", label: "关于" }
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <Seo title={title} description={description} image={image} type={type} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/" aria-label="返回首页">
        <span class="brand-mark">AI</span>
        <span class="brand-text">你的名字</span>
      </a>
      <nav aria-label="主导航">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>© 2026 你的名字</span>
      <span>GitHub · Email · Resume</span>
    </footer>
  </body>
</html>
