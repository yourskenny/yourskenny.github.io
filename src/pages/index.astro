---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PostRow from "../components/PostRow.astro";

const allProjects = await getCollection("projects");
const portfolioProjects = allProjects
  .filter((project) => project.data.category !== "课程归档")
  .sort((a, b) => Number(b.data.highlight) - Number(a.data.highlight) || b.data.date.valueOf() - a.data.date.valueOf());
const courseProjects = allProjects.filter((project) => project.data.category === "课程归档");

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const representativeProjectConfigs = [
  {
    id: "lcfc-nl2sql-intelligent-query",
    label: "代表项目 01 · Agent / NL2SQL",
    signal: "受控 IR、SQL compiler、结果契约、benchmark 与提交校验",
    tools: ["Python", "SQLite", "IR", "SQL Guardrails", "Benchmark", "Truthfulness Gate"]
  },
  {
    id: "ai-pr-review-assistant",
    label: "代表项目 02 · 开发者工具",
    signal: "GitHub PR diff 解析、低噪声 finding、SARIF 与 Dashboard",
    tools: ["GitHub API", "Typer", "FastAPI", "SARIF", "Dashboard", "pytest"]
  },
  {
    id: "marketing-agent-workbench",
    label: "代表项目 03 · 业务 Agent",
    signal: "商贸营销智能体、工作流编排、上下文管理与 API 接入边界",
    tools: ["LLM Agent", "Workflow", "REST API", "Context", "LangGraph", "RAG"]
  }
];

const representativeProjects = representativeProjectConfigs.flatMap((config) => {
  const project = portfolioProjects.find((candidate) => candidate.id === config.id);

  if (!project) {
    return [];
  }

  return [
    {
      ...config,
      project,
      links:
        project.data.links.length > 0
          ? project.data.links
          : [{ label: "项目详情", url: `/projects/${project.id}/` }]
    }
  ];
});

const commonAiTools = ["Codex", "Claude Code", "LiteLLM", "MCP", "NL2SQL", "PR Review", "Phoenix", "Qwen-VL"];
---

<BaseLayout
  title="yourskenny | AI Portfolio"
  description="武汉大学人工智能专业学生的 Agent、CV、DL、RL、EAI 与 NLP 项目作品集"
>
  <section class="hero-shell">
    <div class="hero-copy-block">
      <p class="eyebrow">Wuhan University · Artificial Intelligence · 2023</p>
      <h1>Hay, hermanos, muchísimo que hacer.</h1>
      <p class="poem-credit">César Vallejo · Los nueve monstruos</p>
      <p class="hero-copy">
        我是 yourskenny，武汉大学 2023 级人工智能专业学生。这里整理我在 AI Agent、受控 NL2SQL、
        AI PR Review、商贸智能体、工业视觉、游戏开发、课程复习工作流和短周期面试交付中的项目、课程归档与技术笔记。
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/projects/">查看项目</a>
        <a class="button" href="/interview/">面试项目</a>
        <a class="button" href="/courses/">课程归档</a>
        <a class="button ghost" href="mailto:2023302111391@whu.edu.cn">联系我</a>
      </div>
    </div>

    <aside class="proof-panel" aria-label="能力概览">
      <div class="panel-heading">
        <span>Portfolio Signal</span>
        <strong>2026</strong>
      </div>
      <div class="proof-grid">
        <div>
          <strong>{portfolioProjects.length}</strong>
          <span>作品项目</span>
        </div>
        <div>
          <strong>{courseProjects.length}</strong>
          <span>课程归档</span>
        </div>
        <div>
          <strong>WHU</strong>
          <span>人工智能专业</span>
        </div>
        <div>
          <strong>{posts.length}</strong>
          <span>技术文章</span>
        </div>
      </div>
      <div class="stack-list">
        <span>PyTorch</span>
        <span>Transformers</span>
        <span>OpenCV</span>
        <span>RAG</span>
        <span>MCP</span>
        <span>Agent</span>
        <span>NL2SQL</span>
        <span>PR Review</span>
        <span>YOLO</span>
        <span>VQNet</span>
      </div>
    </aside>
  </section>

  <section class="content-band representative-band" aria-label="代表项目与工具链">
    <div class="section-heading">
      <div>
        <p class="section-label">Representative Work</p>
        <h2>代表项目与工具链</h2>
      </div>
      <a class="text-link" href="/projects/">查看全部项目</a>
    </div>

    <div class="representative-grid">
      {
        representativeProjects.map((item) => (
          <article class="representative-card">
            <div class="representative-meta">
              <span>{item.label}</span>
              <strong>{item.signal}</strong>
            </div>
            <h3>{item.project.data.title}</h3>
            <p>{item.project.data.summary}</p>
            <div>
              <span class="mini-label">主要技术栈</span>
              <div class="stack-row" aria-label={`${item.project.data.title} 主要技术栈`}>
                {item.project.data.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
            </div>
            <div>
              <span class="mini-label">项目使用的 AI 工具</span>
              <div class="stack-row" aria-label={`${item.project.data.title} AI 工具`}>
                {item.tools.map((tool) => (
                  <span>{tool}</span>
                ))}
              </div>
            </div>
            <div class="link-row">
              {item.links.map((link) => (
                <a class="button" href={link.url}>
                  {link.label}
                </a>
              ))}
            </div>
          </article>
        ))
      }
    </div>

    <div class="tool-rail">
      <div>
        <p class="section-label">AI Tools</p>
        <h3>常用 AI 工具</h3>
        <p>日常围绕 Agent 编排、代码生成、模型路由、视觉语言理解、工作流构建和 trace 复盘建立工具链。</p>
      </div>
      <div class="stack-row" aria-label="常用 AI 工具">
        {commonAiTools.map((tool) => <span>{tool}</span>)}
      </div>
    </div>
  </section>

  <section class="bento-grid" aria-label="核心能力">
    <a class="bento-card large" href="/projects/">
      <span class="section-label">Projects</span>
      <h2>从真实项目中抽象研究问题和工程闭环。</h2>
      <p>作品集覆盖 LCFC 受控 NL2SQL、AI PR Review、商贸营销智能体、工业预测、游戏开发、CCF 本源杯和面试交付等方向。</p>
    </a>
    <a class="bento-card" href="/interview/">
      <span class="section-label">Interview</span>
      <h2>面试项目</h2>
      <p>Rubric 试标和 YAHAHA 三天 MVP 单独归档，展示短周期交付、验证命令和公开边界。</p>
    </a>
    <a class="bento-card" href="/courses/">
      <span class="section-label">Courses</span>
      <h2>课程归档</h2>
      <p>数字逻辑、计算机视觉、DSP、数据结构等课程项目单独归档，保留学习轨迹。</p>
    </a>
    <a class="bento-card" href="/research/">
      <span class="section-label">Research</span>
      <h2>研究原型</h2>
      <p>强化学习、Mini-Transformer、计算社会科学和具身智能原型，会继续沉淀为实验记录与技术文章。</p>
    </a>
  </section>

  <section class="content-band">
    <div class="section-heading">
      <div>
        <p class="section-label">Selected Work</p>
        <h2>代表项目</h2>
      </div>
      <a class="text-link" href="/projects/">全部项目</a>
    </div>
    <div class="project-grid">
      {portfolioProjects.slice(0, 6).map((project, index) => <ProjectCard project={project} featured={index === 0} />)}
    </div>
  </section>

  <section class="content-band split-band">
    <div>
      <p class="section-label">Archive Strategy</p>
      <h2>课程项目不丢，但不抢主线</h2>
    </div>
    <div class="evidence-list">
      <article>
        <span>独立抽象</span>
        <p>能体现完整系统、真实场景或明确技术闭环的项目，单独进入作品集，例如 LCFC、AI PR Review、商贸智能体、FeO、Lumina。</p>
      </article>
      <article>
        <span>课程归档</span>
        <p>以课堂训练、作业集合、基础实验为主的内容，统一放入课程大类，证明基础但不稀释代表项目。</p>
      </article>
      <article>
        <span>面试项目</span>
        <p>面试或试标交付单独归档，保留方法、边界和验证链路，不公开对方原始材料。</p>
      </article>
      <article>
        <span>弱经历复盘</span>
        <p>非主导、未获奖或失败实验不包装成核心项目，改写成边界清楚的复盘，例如 YOLO-FD 和开物扫雷。</p>
      </article>
    </div>
  </section>

  <section class="content-band writing-band">
    <div class="section-heading">
      <div>
        <p class="section-label">Writing</p>
        <h2>最新文章</h2>
      </div>
      <a class="text-link" href="/blog/">全部文章</a>
    </div>
    <div class="post-list">
      {posts.slice(0, 3).map((post) => <PostRow post={post} />)}
    </div>
  </section>
</BaseLayout>
