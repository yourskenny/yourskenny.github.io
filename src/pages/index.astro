---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import PostRow from "../components/PostRow.astro";

const projects = (await getCollection("projects"))
  .filter((project) => project.data.highlight)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="你的名字 | AI Portfolio">
  <section class="hero-shell">
    <div class="hero-copy-block">
      <p class="eyebrow">AI Undergraduate · Research + Engineering</p>
      <h1>把 AI 项目沉淀成可信的研究与工程证据。</h1>
      <p class="hero-copy">
        我关注计算机视觉、深度学习工程化和可信 AI。这个网站整理我的项目案例、论文笔记、
        工程实践和考研/求职准备材料。
      </p>
      <div class="hero-actions">
        <a class="button primary" href="/projects/">查看项目</a>
        <a class="button" href="/blog/">阅读笔记</a>
        <a class="button ghost" href="/resume-placeholder.pdf">简历</a>
      </div>
    </div>

    <aside class="proof-panel" aria-label="能力概览">
      <div class="panel-heading">
        <span>Portfolio Signal</span>
        <strong>2026</strong>
      </div>
      <div class="proof-grid">
        <div>
          <strong>{projects.length}</strong>
          <span>代表项目</span>
        </div>
        <div>
          <strong>{posts.length}</strong>
          <span>技术文章</span>
        </div>
        <div>
          <strong>3</strong>
          <span>研究方向</span>
        </div>
        <div>
          <strong>AI</strong>
          <span>专业背景</span>
        </div>
      </div>
      <div class="stack-list">
        <span>Python</span>
        <span>PyTorch</span>
        <span>OpenCV</span>
        <span>RAG</span>
        <span>Astro</span>
      </div>
    </aside>
  </section>

  <section class="bento-grid" aria-label="核心能力">
    <a class="bento-card large" href="/projects/">
      <span class="section-label">Projects</span>
      <h2>项目案例不是链接堆砌，而是问题、方法、结果和复盘。</h2>
      <p>面向面试官展示工程闭环，面向导师展示问题意识和实验分析。</p>
    </a>
    <a class="bento-card" href="/research/">
      <span class="section-label">Research</span>
      <h2>研究兴趣</h2>
      <p>梳理计算机视觉、深度学习工程化、可信 AI 等方向。</p>
    </a>
    <a class="bento-card" href="/blog/">
      <span class="section-label">Writing</span>
      <h2>持续写作</h2>
      <p>项目复盘、论文笔记、工程踩坑和考研基础。</p>
    </a>
  </section>

  <section class="content-band">
    <div class="section-heading">
      <div>
        <p class="section-label">Selected Work</p>
        <h2>代表项目</h2>
      </div>
      <a class="text-link" href="/projects/">全部项目</a>
    </div>
    <div class="project-grid">
      {projects.map((project, index) => <ProjectCard project={project} featured={index === 0} />)}
    </div>
  </section>

  <section class="content-band split-band">
    <div>
      <p class="section-label">For Reviewers</p>
      <h2>不同读者看到不同证据</h2>
    </div>
    <div class="evidence-list">
      <article>
        <span>导师 / 复试</span>
        <p>论文阅读、实验复现、方法选择理由、失败案例分析和后续研究计划。</p>
      </article>
      <article>
        <span>招聘 / 面试</span>
        <p>数据处理、训练流程、评估指标、系统部署、代码结构和项目复盘。</p>
      </article>
    </div>
  </section>

  <section class="content-band writing-band">
    <div class="section-heading">
      <div>
        <p class="section-label">Writing</p>
        <h2>最新文章</h2>
      </div>
      <a class="text-link" href="/blog/">全部文章</a>
    </div>
    <div class="post-list">
      {posts.slice(0, 3).map((post) => <PostRow post={post} />)}
    </div>
  </section>
</BaseLayout>
