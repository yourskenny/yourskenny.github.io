---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectCard from "../../components/ProjectCard.astro";

const interviewProjects = (await getCollection("projects"))
  .filter((project) => project.data.category === "面试项目")
  .sort((a, b) => Number(b.data.highlight) - Number(a.data.highlight) || b.data.date.valueOf() - a.data.date.valueOf());

const notes = [
  {
    title: "短周期交付",
    body: "重点展示三天到数天内如何把高风险链路先跑通，并保留可复现命令、文档和验证结果。"
  },
  {
    title: "证据边界",
    body: "只公开方法、架构、产物结构和可迁移经验，不公开题包、平台地址、内部链接或对方材料。"
  },
  {
    title: "工程判断",
    body: "强调需求拆解、取舍、质量门禁、自检清单和生产化 tradeoff，而不是把 demo 包装成完整商业系统。"
  }
];
---

<BaseLayout
  title="面试项目 | AI Portfolio"
  description="yourskenny 的面试项目归档，整理短周期交付、AI Agent 工程和评测设计相关作品。"
>
  <section class="page-hero compact">
    <p class="eyebrow">Interview Projects</p>
    <h1>面试项目</h1>
    <p>
      这里收录面试或试标期间完成的短周期交付。它们不和长期项目混在一起展示，
      重点看需求理解、工程闭环、验证方式和公开边界。
    </p>
  </section>

  <section class="content-band split-band">
    <div>
      <p class="section-label">Boundary</p>
      <h2>公开的是方法和交付能力，不是题包本身</h2>
    </div>
    <div class="evidence-list">
      <article>
        <span>可公开</span>
        <p>系统设计、项目结构、验证命令、交付文档、方法复盘和已经脱敏的经验总结。</p>
      </article>
      <article>
        <span>不公开</span>
        <p>面试方原始材料、平台地址、内部链接、正式题包、账号信息、提交文件或未授权数据。</p>
      </article>
    </div>
  </section>

  <section class="content-band">
    <div class="section-heading">
      <div>
        <p class="section-label">Delivered Work</p>
        <h2>已整理项目</h2>
      </div>
      <span class="muted-count">{interviewProjects.length} items</span>
    </div>
    <div class="project-grid">
      {interviewProjects.map((project, index) => <ProjectCard project={project} featured={index === 0} />)}
    </div>
  </section>

  <section class="content-band">
    <div class="section-heading">
      <div>
        <p class="section-label">Review Lens</p>
        <h2>阅读这些项目时看什么</h2>
      </div>
    </div>
    <div class="interview-note-grid">
      {
        notes.map((note) => (
          <article class="interview-note">
            <h3>{note.title}</h3>
            <p>{note.body}</p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
