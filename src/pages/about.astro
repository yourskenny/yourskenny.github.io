---
import BaseLayout from "../layouts/BaseLayout.astro";

const techStacks = [
  {
    label: "Foundation",
    items: ["Python", "C/C++", "JavaScript", "TypeScript", "Git", "Linux", "PowerShell"]
  },
  {
    label: "Agent",
    items: ["RAG", "MCP", "LangChain", "OpenAI API", "LiteLLM", "Prompt Engineering", "Tool Calling"]
  },
  {
    label: "CV",
    items: ["OpenCV", "YOLO", "Detection", "Segmentation", "Image Classification", "Multimodal Perception"]
  },
  {
    label: "DL",
    items: ["PyTorch", "Transformers", "scikit-learn", "NumPy", "Pandas", "Matplotlib", "Training Pipeline"]
  },
  {
    label: "RL",
    items: ["Gymnasium", "Q-Learning", "DQN", "Policy Gradient", "MCTS", "Game AI"]
  },
  {
    label: "EAI / NLP",
    items: ["Robotics", "Navigation", "Sensor Fusion", "LLM", "Mini-Transformer", "Tokenization", "Evaluation"]
  },
  {
    label: "Engineering",
    items: ["Astro", "Node.js", "Docker", "FastAPI", "SQLite", "Observability", "GitHub Pages"]
  }
];
---

<BaseLayout
  title="关于 yourskenny | AI Portfolio"
  description="yourskenny 是武汉大学 2023 级人工智能专业学生，关注 Agent、CV、DL、RL、EAI 与 NLP。"
>
  <section class="page-hero compact">
    <p class="eyebrow">About</p>
    <h1>你好，我是 yourskenny</h1>
    <p>武汉大学 2023 级人工智能专业学生，长期关注 Agent、计算机视觉、深度学习、强化学习、具身智能和自然语言处理。</p>
  </section>

  <section class="content-band about-layout">
    <div class="about-copy">
      <p>
        我把这个网站作为个人 AI 项目与学习轨迹的长期档案：一方面记录可运行、可复盘的工程项目，
        另一方面沉淀课程实验、研究原型和技术文章，方便后续科研训练、导师沟通与实习求职。
      </p>
      <a class="button primary" href="mailto:2023302111391@whu.edu.cn">邮件联系</a>
    </div>
    <div class="info-panel">
      <h2>基本信息</h2>
      <dl>
        <dt>学校</dt>
        <dd>武汉大学 / 人工智能专业 / 2023 级</dd>
        <dt>方向</dt>
        <dd>Agent, CV, DL, RL, EAI, NLP</dd>
        <dt>技能</dt>
        <dd>Python, PyTorch, OpenCV, Transformers, RAG, MCP, Astro, Node.js</dd>
        <dt>联系</dt>
        <dd><a href="mailto:2023302111391@whu.edu.cn">2023302111391@whu.edu.cn</a></dd>
        <dt>GitHub</dt>
        <dd><a href="https://github.com/yourskenny">github.com/yourskenny</a></dd>
      </dl>
    </div>
  </section>

  <section class="content-band">
    <div class="section-heading">
      <div>
        <p class="section-label">Tech Stack</p>
        <h2>技术栈</h2>
      </div>
    </div>
    <div class="skill-matrix">
      {
        techStacks.map((group) => (
          <article class="skill-group">
            <h3>{group.label}</h3>
            <div class="tags">
              {group.items.map((item) => <span>{item}</span>)}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
