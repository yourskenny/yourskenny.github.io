---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout title={`${project.data.title} | 项目`}>
  <article class="prose">
    <a class="back-link" href="/projects/">返回项目列表</a>
    <p class="eyebrow">{project.data.role}</p>
    <h1>{project.data.title}</h1>
    <p class="lead">{project.data.summary}</p>
    <div class="detail-meta">
      <span>{project.data.category}</span>
      {project.data.sourcePath && <span>{project.data.sourcePath}</span>}
    </div>
    <div class="tags">
      {project.data.tags.map((tag) => <span>{tag}</span>)}
    </div>
    <Content />
  </article>
</BaseLayout>
